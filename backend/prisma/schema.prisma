generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id        Int      @id @default(autoincrement())
  week      String
  period    String
  serviceId   Int
  status    String   @default("pending")
  service   Service  @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())
}

model Service {
id        Int      @id @default(autoincrement())
title     String
desc      String
price     Int

bookings Booking[]
}